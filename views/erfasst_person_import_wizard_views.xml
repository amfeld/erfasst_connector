<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_erfasst_person_import_wizard_form" model="ir.ui.view">
        <field name="name">erfasst.person.import.wizard.form</field>
        <field name="model">erfasst.person.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Personen aus 123erfasst">
                <field name="state" invisible="1"/>
                <sheet>

                    <!-- Step 1: select (trigger load) -->
                    <div invisible="state != 'select'">
                        <div class="alert alert-info" role="alert">
                            Alle Personen aus 123erfasst laden und mit Odoo-Mitarbeitern abgleichen.
                        </div>
                    </div>

                    <!-- Step 2: preview + assignment -->
                    <div invisible="state != 'preview'">
                        <field name="line_ids" nolabel="1">
                            <tree editable="top"
                                  decoration-success="status == 'mapped'"
                                  decoration-muted="not employee_id and status == 'new'">
                                <field name="status" string=" " widget="badge"
                                       decoration-success="status == 'mapped'"
                                       decoration-info="status == 'new'"
                                       readonly="1"/>
                                <field name="erfasst_name" string="Name (123erfasst)" readonly="1"/>
                                <field name="erfasst_email" string="E-Mail" readonly="1"/>
                                <field name="employee_id" string="Odoo-Mitarbeiter"
                                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                                <field name="erfasst_ident" string="Ident" optional="hide" readonly="1"/>
                            </tree>
                        </field>
                    </div>

                    <!-- Step 3: done -->
                    <div invisible="state != 'done'" class="alert alert-success o_field_widget" role="alert">
                        <i class="fa fa-check-circle me-2"/>
                        <strong>Fertig — </strong>
                        <field name="imported_count" nolabel="1" readonly="1" class="d-inline"/>
                        <span> Zuordnung(en) gespeichert.</span>
                    </div>

                </sheet>
                <footer>
                    <button name="action_fetch"
                            string="Personen laden"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'select'"/>
                    <button name="action_confirm"
                            string="Zuordnung speichern"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'preview'"/>
                    <button name="action_back"
                            string="Zurück"
                            type="object"
                            invisible="state not in ('preview', 'done')"/>
                    <button string="Abbrechen"
                            class="btn-secondary"
                            special="cancel"
                            invisible="state == 'done'"/>
                    <button string="Schließen"
                            class="btn-secondary"
                            special="cancel"
                            invisible="state != 'done'"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_erfasst_person_import_wizard" model="ir.actions.act_window">
        <field name="name">Personen aus 123erfasst</field>
        <field name="res_model">erfasst.person.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menuitem under HR configuration -->
    <menuitem id="menu_erfasst_person_import"
              name="Personen aus 123erfasst importieren"
              parent="hr.menu_human_resources_configuration"
              action="action_erfasst_person_import_wizard"
              groups="erfasst_connector.group_erfasst_manager"
              sequence="91"/>
</odoo>
