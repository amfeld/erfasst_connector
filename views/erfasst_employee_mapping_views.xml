<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_erfasst_employee_mapping_list" model="ir.ui.view">
        <field name="name">erfasst.employee.mapping.list</field>
        <field name="model">erfasst.employee.mapping</field>
        <field name="arch" type="xml">
            <tree string="123erfasst Mitarbeiter-Zuordnung" editable="bottom">
                <field name="employee_id"/>
                <field name="erfasst_person_ident"/>
                <field name="erfasst_person_name"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_erfasst_employee_mapping_form" model="ir.ui.view">
        <field name="name">erfasst.employee.mapping.form</field>
        <field name="model">erfasst.employee.mapping</field>
        <field name="arch" type="xml">
            <form string="123erfasst Mitarbeiter-Zuordnung">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="erfasst_person_ident"/>
                        <field name="erfasst_person_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_erfasst_employee_mapping" model="ir.actions.act_window">
        <field name="name">123erfasst Mitarbeiter-Zuordnung</field>
        <field name="res_model">erfasst.employee.mapping</field>
        <field name="view_mode">tree,form</field>
    </record>


    <!-- Menu: Employees → Konfiguration → 123erfasst-Zuordnung -->
    <menuitem id="menu_erfasst_employee_mapping"
              name="123erfasst-Zuordnung"
              parent="hr.menu_human_resources_configuration"
              action="action_erfasst_employee_mapping"
              groups="erfasst_connector.group_erfasst_manager"
              sequence="90"/>

</odoo>
